{
  "name": "coding-agent",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "extensions/*"
  ],
  "scripts": {
    "build": "pnpm -r run build",
    "build:ui": "pnpm --filter @coding-agent/web build",
    "dev": "node scripts/dev.mjs",
    "dev:stop": "node scripts/dev.mjs stop",
    "dev:status": "node scripts/dev.mjs status",
    "test": "pnpm --filter @coding-agent/mcp-server test && pnpm --filter @coding-agent/web test",
    "lint": "pnpm -r run lint"
  }
}