# Example environment configuration for coding-agent
# Copy to .env.local and fill in your secrets:
#   cp .env.example .env.local

# Mistral API key used by the Mistral client.
MISTRAL_API_KEY=

# Mistral model to use for chat completions (e.g. codestral-latest, mistral-small-latest)
MISTRAL_MODEL=codestral-latest

# Workspace root directory. This controls where the MCP server is allowed to read/write.
WORKSPACE_ROOT=/path/to/your/repository

# Optional comma-separated directories where local projects are searched.
# By default the catalog scans the workspace plus ~/Projects, ~/Developer, ~/Code,
# ~/Documents and ~/Desktop.
# PROJECTS_ROOTS=/Users/you/Projects,/Users/you/Code

# MCP server port and URL used by agent-core to call local tools.
MCP_SERVER_PORT=3000
MCP_SERVER_URL=http://127.0.0.1:3000